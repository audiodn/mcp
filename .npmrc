; The `agents` package (used only for the Cloudflare Worker's createMcpHandler)
; declares a hard peer on zod@^4, but this package and @modelcontextprotocol/sdk
; use zod@^3 (our zodToJsonSchema reads zod v3 internals). The Worker only imports
; `agents/mcp` protocol plumbing, which does not depend on zod v4 at runtime, so we
; keep zod v3 and relax peer resolution here (and in CI via npm ci).
legacy-peer-deps=true
